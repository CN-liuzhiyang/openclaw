# OpenClaw Environment Configuration
# Copy this to the project root as .env and fill in your values.

# =============================================================================
# Gateway Configuration
# =============================================================================
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Gateway auth token (auto-generated if not set)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Docker image (use "openclaw:local" to build from source)
OPENCLAW_IMAGE=openclaw:local

# =============================================================================
# AI Provider API Keys (set at least one)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# =============================================================================
# Messaging Channels (optional)
# =============================================================================
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# =============================================================================
# Advanced (usually not needed)
# =============================================================================
# OPENCLAW_SANDBOX=
# OPENCLAW_DOCKER_SOCKET=
# OPENCLAW_EXTRA_MOUNTS=
# OPENCLAW_HOME_VOLUME=
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
